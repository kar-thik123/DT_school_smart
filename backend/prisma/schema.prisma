generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                          String                        @id @default(uuid()) @db.Uuid
  school_name                 String
  school_type                 String?
  medium                      String?
  contact_email               String?
  contact_phone               String?
  address                     String?
  logo_url                    String?
  domain_type                 String                        @default("subdomain")
  subdomain                   String?                       @unique
  custom_domain               String?
  smtp_host                   String?
  smtp_port                   Int?
  smtp_email                  String?
  smtp_password               String?
  backup_enabled              Boolean                       @default(false)
  status                      OrganizationStatus            @default(DRAFT)
  login_limit                 Int                           @default(100)
  created_at                  DateTime                      @default(now())
  academic_years              AcademicYear[]
  boards                      Board[]
  grades                      Grade[]
  internal_mails              InternalMail[]
  master_grades               MasterGrade[]
  mediums                     Medium[]
  license                     OrganizationLicense?
  organization_types          OrganizationType[]
  practice_attempts           PracticeAttempt[]
  student_assessment_attempts StudentAssessmentAttempt[]
  promotion_history           PromotionHistory[]
  questions                   Question[]
  roles                       Role[]
  sections                    Section[]
  student_enrollments         StudentEnrollment[]
  student_group_mappings      StudentGroupMapping[]
  student_profiles            StudentProfile[]
  StudentTransferHistory      StudentTransferHistory[]
  subject_groups              SubjectGroup[]
  subjects                    Subject[]
  syllabuses                  Syllabus[]
  teacher_assignments         TeacherAssignment[]
  topic_activations           TopicActivation[]
  topics                      Topic[]
  sub_topics                  SubTopic[]
  units                       Unit[]
  users                       User[]
  user_profiles               UserProfile[]
  notifications               Notification[]
  completion_trackings        CompletionTracking[]
  module_configs              ModuleConfig[]
  audit_logs                  AuditLog[]
  notification_preferences    NotificationPreference[]
  SkillVerificationAssignment SkillVerificationAssignment[]
  Skill                       Skill[]

  @@index([subdomain])
  @@map("organizations")
}

model OrganizationLicense {
  id                String        @id @default(uuid()) @db.Uuid
  organization_id   String        @unique @db.Uuid
  licensed_seats    Int           @default(100)
  renewal_date      DateTime?
  grace_period_days Int           @default(7)
  warning_threshold Int           @default(80)
  status            LicenseStatus @default(ACTIVE)
  internal_notes    String?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  organization      Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("organization_licenses")
}

model User {
  id                          String                        @id @default(uuid()) @db.Uuid
  name                        String
  email                       String                        @unique
  password_hash               String
  role_id                     String                        @db.Uuid
  organization_id             String                        @db.Uuid
  grade_id                    String?                       @db.Uuid
  section_id                  String?                       @db.Uuid
  is_active                   Boolean                       @default(true)
  created_at                  DateTime                      @default(now())
  updated_at                  DateTime                      @default(now()) @updatedAt
  mails_received              InternalMail[]                @relation("MailReceiver")
  mails_sent                  InternalMail[]                @relation("MailSender")
  password_resets             PasswordReset[]
  practice_attempts           PracticeAttempt[]
  student_assessment_attempts StudentAssessmentAttempt[]
  promotions_made             PromotionHistory[]            @relation("PromotedBy")
  promotion_history           PromotionHistory[]            @relation("PromotionStudent")
  questions                   Question[]
  enrollments                 StudentEnrollment[]
  student_group_mappings      StudentGroupMapping[]
  student_profile             StudentProfile?
  user_profile                UserProfile?
  transfer_history_as_creator StudentTransferHistory[]      @relation("TransferCreator")
  transfer_history_as_student StudentTransferHistory[]      @relation("TransferStudent")
  teacher_assignments         TeacherAssignment[]
  grade                       Grade?                        @relation(fields: [grade_id], references: [id])
  organization                Organization                  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  role                        Role                          @relation(fields: [role_id], references: [id])
  section                     Section?                      @relation(fields: [section_id], references: [id])
  notification_recipients     NotificationRecipient[]
  skills                      Skill[]                       @relation("SkillOwner")
  verified_skills             Skill[]                       @relation("SkillVerifier")
  // completed_by isn't strict referential integrity for Users to keep schema clean, or we can use relation. I'll omit it and not use relation to avoid User model clutter.
  SkillVerificationAssignment SkillVerificationAssignment[]

  @@index([organization_id])
  @@index([email])
  @@index([role_id])
  @@index([grade_id])
  @@index([section_id])
  @@map("users")
}

model StudentProfile {
  id               String       @id @default(uuid()) @db.Uuid
  user_id          String       @unique @db.Uuid
  organization_id  String       @db.Uuid
  admission_number String?
  mobile_number    String?
  date_of_birth    DateTime?    @db.Date
  academic_birth   DateTime?    @db.Date
  created_at       DateTime     @default(now())
  updated_at       DateTime     @default(now()) @updatedAt
  organization     Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, admission_number])
  @@map("student_profiles")
}

model UserProfile {
  id                String  @id @default(uuid()) @db.Uuid
  user_id           String  @unique @db.Uuid
  organization_id   String  @db.Uuid
  phone             String?
  city              String?
  country           String?
  address           String?
  about             String?
  profile_image     String?
  academic_profiles Json?   @default("[]")

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model PasswordReset {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
  @@map("password_resets")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  organization_id String?          @db.Uuid
  is_system       Boolean          @default(false)
  permissions     RolePermission[]
  created_at      DateTime         @default(now())
  updated_at      DateTime         @default(now()) @updatedAt
  organization    Organization?    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  users           User[]

  @@unique([name, organization_id])
  @@index([organization_id])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  module      String
  action      String
  description String?
  roles       RolePermission[]
  created_at  DateTime         @default(now())
  updated_at  DateTime         @default(now()) @updatedAt

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model Board {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  organization_id String       @db.Uuid
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  syllabuses      Syllabus[]

  @@unique([name, organization_id])
  @@map("boards")
}

model Medium {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  organization_id String       @db.Uuid
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([name, organization_id])
  @@map("mediums")
}

model OrganizationType {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  organization_id String       @db.Uuid
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([name, organization_id])
  @@map("organization_types")
}

model AcademicYear {
  id                       String                     @id @default(uuid()) @db.Uuid
  name                     String
  start_date               DateTime?
  end_date                 DateTime?
  is_active                Boolean                    @default(true)
  organization_id          String                     @db.Uuid
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @default(now()) @updatedAt
  organization             Organization               @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  grades                   Grade[]
  promotion_from           PromotionHistory[]         @relation("FromAcademicYear")
  promotion_to             PromotionHistory[]         @relation("ToAcademicYear")
  enrollments              StudentEnrollment[]
  student_transfer_history StudentTransferHistory[]   @relation("TransferAcademicYear")
  teacher_assignments      TeacherAssignment[]
  completion_trackings     CompletionTracking[]
  practice_attempts        PracticeAttempt[]
  assessment_attempts      StudentAssessmentAttempt[]
  student_group_mappings   StudentGroupMapping[]
  topic_activations        TopicActivation[]
  Skill                    Skill[]

  @@unique([name, organization_id])
  @@index([organization_id])
  @@map("academic_years")
}

model MasterGrade {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  sort_order      Int      @default(0)
  organization_id String   @db.Uuid
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  organization   Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  grades         Grade[]
  subjects       Subject[]
  subject_groups SubjectGroup[]

  @@unique([name, organization_id])
  @@index([organization_id])
  @@map("master_grades")
}

model Grade {
  id                          String                        @id @default(uuid()) @db.Uuid
  name                        String
  academic_year_id            String                        @db.Uuid
  organization_id             String                        @db.Uuid
  master_grade_id             String?                       @db.Uuid
  sort_order                  Int                           @default(0)
  is_active                   Boolean                       @default(true)
  created_at                  DateTime                      @default(now())
  updated_at                  DateTime                      @default(now()) @updatedAt
  academic_year               AcademicYear                  @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  master_grade                MasterGrade?                  @relation(fields: [master_grade_id], references: [id], onDelete: Cascade)
  organization                Organization                  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  promotion_from              PromotionHistory[]            @relation("FromGrade")
  promotion_to                PromotionHistory[]            @relation("ToGrade")
  sections                    Section[]
  enrollments                 StudentEnrollment[]
  transfer_history_from       StudentTransferHistory[]      @relation("TransferFromGrade")
  transfer_history_to         StudentTransferHistory[]      @relation("TransferToGrade")
  subject_groups              SubjectGroup[]
  subjects                    Subject[]
  teacher_assignments         TeacherAssignment[]
  units                       Unit[]
  users                       User[]
  questions                   Question[]
  completion_trackings        CompletionTracking[]
  SkillVerificationAssignment SkillVerificationAssignment[]

  @@unique([name, academic_year_id, organization_id])
  @@index([organization_id])
  @@index([academic_year_id])
  @@map("grades")
}

model Section {
  id                          String                        @id @default(uuid()) @db.Uuid
  name                        String
  grade_id                    String                        @db.Uuid
  organization_id             String                        @db.Uuid
  sort_order                  Int                           @default(0)
  is_active                   Boolean                       @default(true)
  capacity                    Int?
  warning_threshold           Int?
  created_at                  DateTime                      @default(now())
  updated_at                  DateTime                      @default(now()) @updatedAt
  grade                       Grade                         @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  organization                Organization                  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  enrollments                 StudentEnrollment[]
  transfer_history_from       StudentTransferHistory[]      @relation("TransferFromSection")
  transfer_history_to         StudentTransferHistory[]      @relation("TransferToSection")
  subject_groups              SubjectGroup[]
  teacher_assignments         TeacherAssignment[]
  units                       Unit[]
  users                       User[]
  questions                   Question[]
  completion_trackings        CompletionTracking[]
  SkillVerificationAssignment SkillVerificationAssignment[]

  @@unique([name, grade_id, organization_id])
  @@index([organization_id])
  @@index([grade_id])
  @@map("sections")
}

model Subject {
  id                          String                     @id @default(uuid()) @db.Uuid
  name                        String
  grade_id                    String                     @db.Uuid
  organization_id             String                     @db.Uuid
  master_grade_id             String?                    @db.Uuid
  sort_order                  Int                        @default(0)
  is_active                   Boolean                    @default(true)
  created_at                  DateTime                   @default(now())
  updated_at                  DateTime                   @default(now()) @updatedAt
  practice_attempts           PracticeAttempt[]
  student_assessment_attempts StudentAssessmentAttempt[]
  questions                   Question[]
  subject_groups              SubjectGroupSubject[]
  grade                       Grade                      @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  master_grade                MasterGrade?               @relation(fields: [master_grade_id], references: [id], onDelete: Cascade)
  organization                Organization               @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  syllabuses                  Syllabus[]
  teacher_assignments         TeacherAssignment[]
  units                       Unit[]
  completion_trackings        CompletionTracking[]

  @@unique([name, grade_id, organization_id])
  @@index([organization_id])
  @@index([grade_id])
  @@map("subjects")
}

model Syllabus {
  id              String       @id @default(uuid()) @db.Uuid
  subject_id      String       @db.Uuid
  board_id        String       @db.Uuid
  organization_id String       @db.Uuid
  description     String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt
  board           Board        @relation(fields: [board_id], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  subject         Subject      @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  units           Unit[]

  @@unique([subject_id, board_id, organization_id])
  @@index([organization_id])
  @@index([subject_id])
  @@index([board_id])
  @@map("syllabuses")
}

model Unit {
  id                   String               @id @default(uuid()) @db.Uuid
  name                 String
  grade_id             String?              @db.Uuid
  section_id           String?              @db.Uuid
  subject_id           String?              @db.Uuid
  syllabus_id          String?              @db.Uuid
  organization_id      String               @db.Uuid
  order_index          Int                  @default(0)
  created_at           DateTime             @default(now())
  updated_at           DateTime             @default(now()) @updatedAt
  questions            Question[]
  topics               Topic[]
  organization         Organization         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  grade                Grade?               @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  section              Section?             @relation(fields: [section_id], references: [id], onDelete: Cascade)
  subject              Subject?             @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  syllabus             Syllabus?            @relation(fields: [syllabus_id], references: [id], onDelete: Cascade)
  completion_trackings CompletionTracking[]

  @@index([organization_id])
  @@index([grade_id])
  @@index([section_id])
  @@index([subject_id])
  @@index([syllabus_id])
  @@map("units")
}

model Topic {
  id                   String               @id @default(uuid()) @db.Uuid
  name                 String
  unit_id              String               @db.Uuid
  organization_id      String               @db.Uuid
  order_index          Int                  @default(0)
  created_at           DateTime             @default(now())
  updated_at           DateTime             @default(now()) @updatedAt
  practice_attempts    PracticeAttempt[]
  questions            Question[]
  topic_activations    TopicActivation[]
  organization         Organization         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  unit                 Unit                 @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  sub_topics           SubTopic[]
  completion_trackings CompletionTracking[]

  @@index([organization_id])
  @@index([unit_id])
  @@map("topics")
}

model SubTopic {
  id                   String               @id @default(uuid()) @db.Uuid
  name                 String
  topic_id             String               @db.Uuid
  organization_id      String               @db.Uuid
  order_index          Int                  @default(0)
  created_at           DateTime             @default(now())
  updated_at           DateTime             @default(now()) @updatedAt
  organization         Organization         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  topic                Topic                @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  questions            Question[]
  completion_trackings CompletionTracking[]

  @@index([organization_id])
  @@index([topic_id])
  @@map("sub_topics")
}

model TeacherAssignment {
  id               String         @id @default(uuid()) @db.Uuid
  organization_id  String         @db.Uuid
  academic_year_id String         @db.Uuid
  teacher_id       String         @db.Uuid
  assignment_type  AssignmentType
  grade_id         String         @db.Uuid
  section_id       String?        @db.Uuid
  subject_id       String?        @db.Uuid
  created_at       DateTime       @default(now())
  updated_at       DateTime       @default(now()) @updatedAt
  academic_year    AcademicYear   @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  grade            Grade          @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  section          Section?       @relation(fields: [section_id], references: [id], onDelete: Cascade)
  subject          Subject?       @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  teacher          User           @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@unique([teacher_id, assignment_type, grade_id, section_id, subject_id, academic_year_id, organization_id], name: "unique_assignment")
  @@index([organization_id])
  @@index([teacher_id])
  @@map("teacher_assignments")
}

model Question {
  id               String           @id @default(uuid()) @db.Uuid
  organization_id  String           @db.Uuid
  created_by       String           @db.Uuid
  grade_id         String?          @db.Uuid
  section_id       String?          @db.Uuid
  subject_id       String?          @db.Uuid
  unit_id          String?          @db.Uuid
  topic_id         String?          @db.Uuid
  sub_topic_id     String?          @db.Uuid
  question_text    String
  type             QuestionType     @default(MCQ_SINGLE)
  answer           String?
  answer_config    Json             @default("{}")
  marks            Int
  difficulty       DifficultyLevel
  is_important     Boolean          @default(false)
  is_repeated      Boolean          @default(false)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now()) @updatedAt
  practice_answers PracticeAnswer[]
  creator          User             @relation(fields: [created_by], references: [id], onDelete: Cascade)
  organization     Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  grade            Grade?           @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  section          Section?         @relation(fields: [section_id], references: [id], onDelete: Cascade)
  subject          Subject?         @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  topic            Topic?           @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  sub_topic        SubTopic?        @relation(fields: [sub_topic_id], references: [id], onDelete: Cascade)
  unit             Unit?            @relation(fields: [unit_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([grade_id, section_id, subject_id, unit_id, topic_id])
  @@map("questions")
}

model TopicActivation {
  id               String        @id @default(uuid()) @db.Uuid
  organization_id  String        @db.Uuid
  topic_id         String        @db.Uuid
  subject_group_id String        @db.Uuid
  academic_year_id String?       @db.Uuid
  is_active        Boolean       @default(true)
  is_completed     Boolean       @default(false)
  completed_at     DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @default(now()) @updatedAt
  academic_year    AcademicYear? @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  subjectGroup     SubjectGroup  @relation(fields: [subject_group_id], references: [id], onDelete: Cascade)
  topic            Topic         @relation(fields: [topic_id], references: [id], onDelete: Cascade)

  @@unique([topic_id, subject_group_id, organization_id])
  @@index([organization_id])
  @@index([academic_year_id])
  @@index([organization_id, academic_year_id])
  @@index([topic_id])
  @@index([subject_group_id])
  @@map("topic_activations")
}

model PracticeAttempt {
  id               String           @id @default(uuid()) @db.Uuid
  organization_id  String           @db.Uuid
  student_id       String           @db.Uuid
  academic_year_id String?          @db.Uuid
  subject_id       String           @db.Uuid
  topic_id         String           @db.Uuid
  total_questions  Int
  correct_answers  Int
  created_at       DateTime         @default(now())
  updated_at       DateTime         @default(now()) @updatedAt
  answers          PracticeAnswer[]
  academic_year    AcademicYear?    @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  organization     Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  student          User             @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subject          Subject          @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  topic            Topic            @relation(fields: [topic_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([student_id])
  @@index([subject_id])
  @@index([topic_id])
  @@map("practice_attempts")
}

model StudentAssessmentAttempt {
  id               String   @id @default(uuid()) @db.Uuid
  organization_id  String   @db.Uuid
  student_id       String   @db.Uuid
  academic_year_id String?  @db.Uuid
  subject_id       String   @db.Uuid
  unit_id          String?  @db.Uuid
  topic_id         String?  @db.Uuid
  sub_topic_id     String?  @db.Uuid
  attempt_count    Int      @default(1)
  start_time       DateTime
  end_time         DateTime
  total_questions  Int
  correct_answers  Int
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt

  academic_year AcademicYear? @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  organization  Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  student       User          @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subject       Subject       @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([student_id])
  @@index([subject_id])
  @@map("student_assessment_attempts")
}

model PracticeAnswer {
  id              String          @id @default(uuid()) @db.Uuid
  attempt_id      String          @db.Uuid
  question_id     String          @db.Uuid
  selected_answer String
  is_correct      Boolean
  created_at      DateTime        @default(now())
  updated_at      DateTime        @default(now()) @updatedAt
  attempt         PracticeAttempt @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question        Question        @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@index([attempt_id])
  @@index([question_id])
  @@map("practice_answers")
}

model SubjectGroup {
  id                    String                   @id @default(uuid()) @db.Uuid
  organization_id       String                   @db.Uuid
  name                  String
  grade_id              String                   @db.Uuid
  section_id            String                   @db.Uuid
  master_grade_id       String?                  @db.Uuid
  created_at            DateTime                 @default(now())
  updated_at            DateTime                 @default(now()) @updatedAt
  enrollments           StudentEnrollment[]
  students              StudentGroupMapping[]
  transfer_history_from StudentTransferHistory[] @relation("TransferFromGroup")
  transfer_history_to   StudentTransferHistory[] @relation("TransferToGroup")
  subjects              SubjectGroupSubject[]
  grade                 Grade                    @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  master_grade          MasterGrade?             @relation(fields: [master_grade_id], references: [id], onDelete: Cascade)
  organization          Organization             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  section               Section                  @relation(fields: [section_id], references: [id], onDelete: Cascade)
  activations           TopicActivation[]

  @@unique([name, grade_id, section_id, organization_id])
  @@index([organization_id])
  @@index([grade_id])
  @@index([section_id])
  @@map("subject_groups")
}

model SubjectGroupSubject {
  group_id     String       @db.Uuid
  subject_id   String       @db.Uuid
  subject_type SubjectType  @default(MANDATORY)
  group        SubjectGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@id([group_id, subject_id])
  @@map("subject_group_subjects")
}

model StudentGroupMapping {
  id               String        @id @default(uuid()) @db.Uuid
  organization_id  String        @db.Uuid
  student_id       String        @db.Uuid
  academic_year_id String?       @db.Uuid
  group_id         String        @db.Uuid
  created_at       DateTime      @default(now())
  updated_at       DateTime      @default(now()) @updatedAt
  academic_year    AcademicYear? @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  group            SubjectGroup  @relation(fields: [group_id], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  student          User          @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, group_id])
  @@index([organization_id])
  @@index([group_id])
  @@map("student_group_mapping")
}

model StudentEnrollment {
  id               String           @id @default(uuid()) @db.Uuid
  organization_id  String           @db.Uuid
  student_id       String           @db.Uuid
  academic_year_id String           @db.Uuid
  grade_id         String           @db.Uuid
  section_id       String?          @db.Uuid
  subject_group_id String?          @db.Uuid
  roll_number      String?
  status           EnrollmentStatus @default(ACTIVE)
  enrollment_date  DateTime         @default(now())
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  academic_year    AcademicYear     @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  grade            Grade            @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  organization     Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  section          Section?         @relation(fields: [section_id], references: [id], onDelete: Cascade)
  student          User             @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subject_group    SubjectGroup?    @relation(fields: [subject_group_id], references: [id], onDelete: Cascade)

  @@unique([student_id, academic_year_id, organization_id])
  @@index([organization_id])
  @@index([grade_id])
  @@index([section_id])
  @@index([subject_group_id])
  @@map("student_enrollments")
}

model PromotionHistory {
  id                    String       @id @default(uuid()) @db.Uuid
  organization_id       String       @db.Uuid
  student_id            String       @db.Uuid
  from_academic_year_id String       @db.Uuid
  to_academic_year_id   String       @db.Uuid
  from_grade_id         String       @db.Uuid
  to_grade_id           String       @db.Uuid
  promoted_by           String       @db.Uuid
  promotion_date        DateTime     @default(now())
  created_at            DateTime     @default(now())
  updated_at            DateTime     @default(now()) @updatedAt
  from_academic_year    AcademicYear @relation("FromAcademicYear", fields: [from_academic_year_id], references: [id], onDelete: Cascade)
  from_grade            Grade        @relation("FromGrade", fields: [from_grade_id], references: [id], onDelete: Cascade)
  organization          Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  promoter              User         @relation("PromotedBy", fields: [promoted_by], references: [id], onDelete: Cascade)
  student               User         @relation("PromotionStudent", fields: [student_id], references: [id], onDelete: Cascade)
  to_academic_year      AcademicYear @relation("ToAcademicYear", fields: [to_academic_year_id], references: [id], onDelete: Cascade)
  to_grade              Grade        @relation("ToGrade", fields: [to_grade_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([student_id])
  @@index([promoted_by])
  @@map("promotion_history")
}

model StudentTransferHistory {
  id                    String        @id @default(uuid()) @db.Uuid
  organization_id       String        @db.Uuid
  student_id            String        @db.Uuid
  academic_year_id      String        @db.Uuid
  from_grade_id         String        @db.Uuid
  from_section_id       String?       @db.Uuid
  from_subject_group_id String?       @db.Uuid
  to_grade_id           String        @db.Uuid
  to_section_id         String?       @db.Uuid
  to_subject_group_id   String?       @db.Uuid
  reason                String?
  created_by            String        @db.Uuid
  transfer_date         DateTime      @default(now())
  created_at            DateTime      @default(now())
  updated_at            DateTime      @default(now()) @updatedAt
  academic_year         AcademicYear  @relation("TransferAcademicYear", fields: [academic_year_id], references: [id], onDelete: Cascade)
  creator               User          @relation("TransferCreator", fields: [created_by], references: [id], onDelete: Cascade)
  from_grade            Grade         @relation("TransferFromGrade", fields: [from_grade_id], references: [id], onDelete: Cascade)
  from_section          Section?      @relation("TransferFromSection", fields: [from_section_id], references: [id])
  from_subject_group    SubjectGroup? @relation("TransferFromGroup", fields: [from_subject_group_id], references: [id])
  organization          Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  student               User          @relation("TransferStudent", fields: [student_id], references: [id], onDelete: Cascade)
  to_grade              Grade         @relation("TransferToGrade", fields: [to_grade_id], references: [id], onDelete: Cascade)
  to_section            Section?      @relation("TransferToSection", fields: [to_section_id], references: [id])
  to_subject_group      SubjectGroup? @relation("TransferToGroup", fields: [to_subject_group_id], references: [id])

  @@index([organization_id])
  @@index([student_id])
  @@index([academic_year_id])
  @@map("student_transfer_history")
}

model InternalMailAttachment {
  id        String       @id @default(uuid()) @db.Uuid
  mailId    String       @db.Uuid
  filename  String
  url       String
  mimetype  String
  size      Int
  createdAt DateTime     @default(now())
  mail      InternalMail @relation(fields: [mailId], references: [id], onDelete: Cascade)

  @@index([mailId])
  @@map("internal_mail_attachments")
}

model InternalMail {
  id                String                   @id @default(uuid()) @db.Uuid
  organization_id   String                   @db.Uuid
  senderId          String                   @db.Uuid
  receiverId        String                   @db.Uuid
  subject           String
  body              String
  status            MailStatus               @default(DRAFT)
  isRead            Boolean                  @default(false)
  isStarred         Boolean                  @default(false)
  isArchived        Boolean                  @default(false)
  deletedBySender   Boolean                  @default(false)
  deletedByReceiver Boolean                  @default(false)
  replyToId         String?                  @db.Uuid
  created_at        DateTime                 @default(now())
  attachments       InternalMailAttachment[]
  organization      Organization             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  receiver          User                     @relation("MailReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  replyTo           InternalMail?            @relation("MailThread", fields: [replyToId], references: [id])
  replies           InternalMail[]           @relation("MailThread")
  sender            User                     @relation("MailSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([senderId])
  @@index([receiverId])
  @@map("internal_mails")
}

enum OrganizationStatus {
  DRAFT
  PROVISIONING
  ACTIVE
  MAINTENANCE
  SUSPENDED
  ARCHIVED
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
  GRACE_PERIOD
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  TRANSFERRED
  WITHDRAWN
  GRADUATED
  ALUMNI
}

enum AssignmentType {
  CLASS_TEACHER
  SUBJECT_TEACHER
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTI
  TRUE_FALSE
  YES_NO
  FILL_BLANK
  DRAG_DROP_FILL
  MATCH_FOLLOWING
  DRAG_DROP_MATCH
  SENTENCE_ORDER
  STRUCTURED_2MARK
  STRUCTURED_5MARK
  LONG_ANSWER
}

enum SubjectType {
  MANDATORY
  OPTIONAL
  ELECTIVE
}

enum MailStatus {
  DRAFT
  SENT
}

model Notification {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  event_type      String
  entity_type     String
  entity_id       String   @db.Uuid
  title           String
  message         String
  actor_id        String?  @db.Uuid
  context_data    Json     @default("{}")
  created_at      DateTime @default(now())

  organization Organization            @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  recipients   NotificationRecipient[]

  @@index([organization_id])
  @@index([entity_id])
  @@map("notifications")
}

model NotificationRecipient {
  id              String    @id @default(uuid()) @db.Uuid
  notification_id String    @db.Uuid
  user_id         String    @db.Uuid
  is_read         Boolean   @default(false)
  read_at         DateTime?

  notification Notification @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, user_id])
  @@index([user_id, is_read])
  @@map("notification_recipients")
}

model NotificationPreference {
  organization_id String  @db.Uuid
  event_type      String
  is_enabled      Boolean @default(true)
  audience_config Json    @default("{}")

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@id([organization_id, event_type])
  @@map("notification_preferences")
}

model PreviewImportData {
  id              String   @id @default(uuid()) @db.Uuid
  session_id      String
  organization_id String   @db.Uuid
  created_by      String   @db.Uuid
  row_number      Int      @default(0)
  raw_data        Json
  match_status    String   @default("PENDING") // EXACT_MATCH, CLOSEST_MATCH, NEW_HIERARCHY, VALIDATION_ERROR
  resolved_data   Json     @default("{}") // resolved IDs, errors, suggestions
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  @@index([session_id])
  @@index([organization_id])
  @@index([created_by])
  @@map("preview_import_data")
}

model ModuleConfig {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  module_name     String
  config_data     Json     @default("{}")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, module_name])
  @@map("module_configs")
}

model CompletionTracking {
  id                   String          @id @default(uuid()) @db.Uuid
  organization_id      String          @db.Uuid
  academic_year_id     String          @db.Uuid
  grade_id             String          @db.Uuid
  section_id           String?         @db.Uuid
  subject_id           String          @db.Uuid
  unit_id              String?         @db.Uuid
  topic_id             String?         @db.Uuid
  sub_topic_id         String?         @db.Uuid
  completion_level     CompletionLevel
  is_completed         Boolean         @default(false)
  completed_by         String?         @db.Uuid
  completed_at         DateTime?
  notification_sent    Boolean         @default(false)
  notification_sent_at DateTime?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  organization  Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  academic_year AcademicYear @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  grade         Grade        @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  section       Section?     @relation(fields: [section_id], references: [id], onDelete: Cascade)
  subject       Subject      @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  unit          Unit?        @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  topic         Topic?       @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  sub_topic     SubTopic?    @relation(fields: [sub_topic_id], references: [id], onDelete: Cascade)

  @@index([organization_id, academic_year_id, grade_id, subject_id])
  @@index([unit_id])
  @@index([topic_id])
  @@index([sub_topic_id])
  @@index([completed_by])
  @@map("completion_tracking")
}

enum CompletionLevel {
  UNIT
  TOPIC
  SUBTOPIC
}

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  user_id         String   @db.Uuid
  user_name       String?
  action_type     String // CREATE, UPDATE, DELETE, TOGGLE, IMPORT, ASSIGN
  entity_type     String // QUESTION, COMPLETION, TEACHER_ASSIGNMENT, SYLLABUS, ROLE_PERMISSION
  entity_id       String
  timestamp       DateTime @default(now())
  metadata        Json?

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([user_id])
  @@index([entity_type, entity_id])
  @@map("audit_logs")
}

model Skill {
  id               String   @id @default(uuid()) @db.Uuid
  user_id          String   @db.Uuid
  organization_id  String?  @db.Uuid
  academic_year_id String?  @db.Uuid
  skill_type       String
  skill_name       String
  images           String[]
  status           String   @default("pending")
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt
  verified_by      String?  @db.Uuid
  remarks          String?

  user          User          @relation("SkillOwner", fields: [user_id], references: [id], onDelete: Cascade)
  verifier      User?         @relation("SkillVerifier", fields: [verified_by], references: [id], onDelete: SetNull)
  organization  Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  academic_year AcademicYear? @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([organization_id])
  @@index([academic_year_id])
  @@map("skills")
}

model SkillVerificationAssignment {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  verifier_id     String   @db.Uuid
  skill_type      String // e.g. "Academic Skills"
  grade_id        String?  @db.Uuid
  section_id      String?  @db.Uuid
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  verifier     User         @relation(fields: [verifier_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  grade        Grade?       @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  section      Section?     @relation(fields: [section_id], references: [id], onDelete: Cascade)

  @@unique([verifier_id, skill_type, grade_id, section_id])
}
