  DRAFT
  PROVISIONING
  ACTIVE
  MAINTENANCE
  SUSPENDED
  ARCHIVED
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
  GRACE_PERIOD
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  TRANSFERRED
  WITHDRAWN
  GRADUATED
  ALUMNI
}

enum AssignmentType {
  CLASS_TEACHER
  SUBJECT_TEACHER
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
