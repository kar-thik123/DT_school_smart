  ELECTIVE
}


enum MailStatus {
  DRAFT
  SENT
}

model Notification {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  userId          String       @db.Uuid
  type            String
  title           String
  message         String
  isRead          Boolean      @default(false)
  referenceId     String?      @db.Uuid
  created_at      DateTime     @default(now())

  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([userId])
  @@index([referenceId])
  @@map("notifications")
}

model PreviewQuestion {
  id              String   @id @default(uuid()) @db.Uuid
  session_id      String
  organization_id String   @db.Uuid
  created_by      String   @db.Uuid
  row_number      Int      @default(0)
  raw_data        Json
  match_status    String   @default("PENDING")  // EXACT_MATCH, CLOSEST_MATCH, NEW_HIERARCHY, VALIDATION_ERROR
  resolved_data   Json     @default("{}")        // resolved IDs, errors, suggestions
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  @@index([session_id])
  @@index([organization_id])
  @@index([created_by])
  @@map("preview_questions")
}

model ModuleConfig {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  module_name     String
  config_data     Json         @default("{}")
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, module_name])
  @@map("module_configs")
}

model CompletionTracking {
  id                   String       @id @default(uuid()) @db.Uuid
  organization_id      String       @db.Uuid
  academic_year_id     String       @db.Uuid
  grade_id             String       @db.Uuid
  section_id           String?      @db.Uuid
  subject_id           String       @db.Uuid
  unit_id              String?      @db.Uuid
  topic_id             String?      @db.Uuid
  sub_topic_id         String?      @db.Uuid
  completion_level     CompletionLevel
  is_completed         Boolean      @default(false)
  completed_by         String?      @db.Uuid
  completed_at         DateTime?
  notification_sent    Boolean      @default(false)
  notification_sent_at DateTime?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  organization         Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  academic_year        AcademicYear @relation(fields: [academic_year_id], references: [id], onDelete: Cascade)
  grade                Grade        @relation(fields: [grade_id], references: [id], onDelete: Cascade)
  section              Section?     @relation(fields: [section_id], references: [id], onDelete: Cascade)
  subject              Subject      @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  unit                 Unit?        @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  topic                Topic?       @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  sub_topic            SubTopic?    @relation(fields: [sub_topic_id], references: [id], onDelete: Cascade)

  @@index([organization_id, academic_year_id, grade_id, subject_id])
  @@index([unit_id])
  @@index([topic_id])
  @@index([sub_topic_id])
  @@index([completed_by])
  @@map("completion_tracking")
}

enum CompletionLevel {
  UNIT
  TOPIC
  SUBTOPIC
}

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  user_id         String   @db.Uuid
  user_name       String?
  action_type     String   // CREATE, UPDATE, DELETE, TOGGLE, IMPORT, ASSIGN
  entity_type     String   // QUESTION, COMPLETION, TEACHER_ASSIGNMENT, SYLLABUS, ROLE_PERMISSION
  entity_id       String
  timestamp       DateTime @default(now())
  metadata        Json?

  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([user_id])
  @@index([entity_type, entity_id])
  @@map("audit_logs")
}
