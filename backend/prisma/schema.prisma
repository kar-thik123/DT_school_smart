  @@index([organization_id, academic_year_id])
  @@index([student_id])
  @@index([grade_id, section_id])
  @@map("student_exam_results")
}

model StudentExamSubjectResult {
  id                     String  @id @default(uuid()) @db.Uuid
  student_exam_result_id String  @db.Uuid
  subject_id             String  @db.Uuid
  
  max_marks      Float
  obtained_marks Float
  pass_marks     Float?
  is_absent      Boolean @default(false)
  
  status         ResultStatus?
  grade          String?
  remarks        String?

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  student_exam_result StudentExamResult @relation(fields: [student_exam_result_id], references: [id], onDelete: Cascade)
  subject             Subject           @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([student_exam_result_id, subject_id])
  @@index([subject_id])
  @@map("student_exam_subject_results")
}
